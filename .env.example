# TeachAgent PostgreSQL config
TEACHAGENT_DATABASE_URL='postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require'
TEACHAGENT_DB_APPLICATION_NAME='teachagent'
TEACHAGENT_DB_CONNECT_TIMEOUT='10'

# TeachAgent web server config
TEACHAGENT_HOST='0.0.0.0'
TEACHAGENT_PORT='8765'

# TeachAgent Azure credential mode
# Required when diagnosis / coach / answer polish need Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT='https://YOUR_PROJECT.services.ai.azure.com/api/projects/proj-default'
AZURE_AI_MODEL_DEPLOYMENT='gpt-4o-mini'

# Local development with `az login`: leave empty or set to '0'
# Cloud deployment with managed identity / service principal: set to '1'
TEACHAGENT_USE_DEFAULT_CREDENTIAL='0'

# Optional when running inside Docker / cloud with service principal
# AZURE_CLIENT_ID='...'
# AZURE_TENANT_ID='...'
# AZURE_CLIENT_SECRET='...'
